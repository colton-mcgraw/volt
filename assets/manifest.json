{
  "version": "1.0",
  "appname": "Volt",
  "default-window-title": "Volt",
  "window-resizable": true,
  "default-window-x": -1,
  "default-window-y": -1,
  "default-window-width": -1,
  "default-window-height": -1,
  "window-resize-border-thickness": 5,
  "window-titlebar-height": 30,
  "window-titlebar-padding": 5,
  "window-titlebar-button-size": 20,
  "window-titlebar-button-spacing": 5,
  "icon": "./images/volt.png",
  "font": "./fonts/DefaultFont.ttf",
  "font-render-mode": "msdf",
  "font-sdf-spread-px": "12",
  "font-sdf-edge": "0.6",
  "font-sdf-aa-strength": "0.5",
  "preview-board": "./images/volt.png",
  "warning-icon": "./images/volt.png",
  "codec-render-test": "./images/codec-render-test.png",
  "ui-font-default": "./images/ui-font-default.png"
}
